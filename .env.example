# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── PostgreSQL / RDS ──────────────────────────────────────────────────────────
# Local dev:  DB_HOST=localhost
# RDS:        DB_HOST=<rds-instance>.xxxx.ap-southeast-1.rds.amazonaws.com
DB_HOST=localhost
DB_PORT=5432
DB_NAME=printmatch
DB_USER=printmatch_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_64_CHAR_HEX_STRING
JWT_EXPIRES_IN=7d

# ── AWS S3 ────────────────────────────────────────────────────────────────────
# On EC2 with IAM Role attached — leave ACCESS_KEY/SECRET empty (uses instance profile)
# For local dev — fill with your IAM user credentials
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=printmatch-files

# ── File upload ───────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50
PRESIGNED_URL_EXPIRES=259200

# ── CORS ──────────────────────────────────────────────────────────────────────
# Local:      http://localhost:5173
# Production: https://printmatch.yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173
